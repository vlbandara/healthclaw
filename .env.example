# Copy to .env and fill in real values.
# ⚠️ NEVER commit real API keys. This file is a TEMPLATE only.
# The actual .env is gitignored for your safety.

# ─── AI Provider ───────────────────────────────────────────────
# Option A: Local (Ollama) — no API key needed, fully private
NANOBOT_AGENTS__DEFAULTS__PROVIDER=ollama
NANOBOT_AGENTS__DEFAULTS__MODEL=gemma:7b
OLLAMA_API_BASE=http://host.docker.internal:11434

# Option B: Hosted provider — uncomment one path and set its key
# NANOBOT_AGENTS__DEFAULTS__PROVIDER=openrouter
# NANOBOT_AGENTS__DEFAULTS__MODEL=openai/gpt-4o-mini
# OPENROUTER_API_KEY=sk-or-your-key-here
#
# Alternative hosted provider still supported in parts of the health setup flow:
# NANOBOT_AGENTS__DEFAULTS__PROVIDER=minimax
# NANOBOT_AGENTS__DEFAULTS__MODEL=MiniMax-M2.7
# MINIMAX_API_KEY=your-key-here

# ─── Telegram ─────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Multi-Tenant Family Mode ─────────────────────────────────
# Set to true so each family member gets their own private workspace
NANOBOT_MULTI_TENANT=true

# ─── Security ─────────────────────────────────────────────────
# Fernet key for encrypting health vault data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HEALTH_VAULT_KEY=

# ─── Database (Docker Compose) ────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ─── Deployment (optional, for self-hosting) ──────────────────
DOMAIN=localhost
COMPOSE_PROJECT_NAME=healthclaw
HEALTH_ONBOARDING_BASE_URL=http://localhost:18080
HEALTH_HTTP_PORT=18080
APP_RELEASE=local
APP_DEPLOYED_AT=

# ─── Image & Tenant Config ───────────────────────────────────
NANOBOT_HEALTH_INSTANCE_IMAGE=healthclaw-orchestrator:latest
NANOBOT_SKIP_SETUP_PROVIDER=false

# ─── Optional Channel Deep Links ─────────────────────────────
HEALTH_TELEGRAM_BOT_URL=
HEALTH_WHATSAPP_CHAT_URL=
WHATSAPP_BRIDGE_TOKEN=
HEALTH_WHATSAPP_BRIDGE_URL=ws://whatsapp-bridge:3001

# ─── Open Wearables (experimental, optional) ────────────────
# Set these only if you want the hosted setup flow to expose wearable linking.
OPENWEARABLES_ENABLED=false
OPENWEARABLES_API_URL=
OPENWEARABLES_API_KEY=
OPENWEARABLES_TIMEOUT_SECONDS=20
OPENWEARABLES_SYNC_WINDOW_DAYS=3
OPENWEARABLES_STALE_AFTER_HOURS=36
