# Copy to .env and fill in. Used by docker compose and local runs.
# Public brand: BiomeClaw. Internal NANOBOT_* variables remain for compatibility.
# For local-only development, prefer .env.local based on .env.local.example.

# Public hostname for Caddy TLS and onboarding links
DOMAIN=health.example.com

# MiniMax (or your configured provider) — one key for all users in multi-tenant mode
MINIMAX_API_KEY=

# Telegram bot from @BotFather (shared bot for all users when multi-tenant)
TELEGRAM_BOT_TOKEN=

# Fernet secret for encrypted health vault (generate a random string)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HEALTH_VAULT_KEY=

# Postgres password for the hosted health registry
POSTGRES_PASSWORD=

# WhatsApp bridge shared secret (must match BRIDGE_TOKEN in bridge)
WHATSAPP_BRIDGE_TOKEN=

# Base URL for onboarding/setup HTML (e.g. https://health.example.com)
HEALTH_ONBOARDING_BASE_URL=

# Release metadata written by deployment automation
APP_RELEASE=
APP_DEPLOYED_AT=

# Image the hosted spawner should clone for per-user coach containers
NANOBOT_HEALTH_INSTANCE_IMAGE=biomeclaw-orchestrator:latest

# Optional deep links shown in setup UI
HEALTH_TELEGRAM_BOT_URL=
HEALTH_WHATSAPP_CHAT_URL=

# Multi-tenant gateway: one workspace per Telegram/WhatsApp user (docker compose passes this through)
# Set to true for shared-bot multi-user; false for classic single-workspace gateway
NANOBOT_MULTI_TENANT=false

# Skip AI key step in hosted setup wizard when operator supplies MINIMAX_API_KEY globally
NANOBOT_SKIP_SETUP_PROVIDER=false
