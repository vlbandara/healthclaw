# Healthclaw runs with zero configuration: `docker compose up` generates its
# own secrets and starts on http://localhost:8080. You only need a .env file
# to OVERRIDE a default below. Copy to .env and uncomment what you want.
#
# (Provider API keys and your Telegram bot are configured per-user in the web
#  setup flow — they do not belong here. Advanced knobs live in
#  .env.advanced.example.)

# Change the host port the web UI binds to (default 8080).
# HEALTH_HTTP_PORT=8080

# Pin a specific published image / tag instead of :latest.
# HEALTHCLAW_IMAGE=ghcr.io/vlbandara/healthclaw:latest

# Public hostname — only needed for the production (Caddy/TLS) overlay.
# DOMAIN=health.example.com
