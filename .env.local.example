# Copy to .env.local for local-only development.
# Use with: docker compose --env-file .env.local up -d --build postgres redis orchestrator worker

# Give local containers and images a separate project namespace.
COMPOSE_PROJECT_NAME=healthclaw-local

# Keep local runtime state inside the repo instead of ~/.nanobot.
NANOBOT_STATE_DIR=.local/nanobot-state

# Publish the local API on a non-production port.
HEALTH_HTTP_PORT=18080

# Optional local Caddy ports if you ever run the caddy service too.
CADDY_HTTP_PORT=18081
CADDY_HTTPS_PORT=18443
DOMAIN=localhost

# Local health API URL
HEALTH_ONBOARDING_BASE_URL=http://localhost:18080

# Set real values when you need hosted-provider setup or channel integrations.
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
TELEGRAM_BOT_TOKEN=
HEALTH_VAULT_KEY=local-dev-vault-secret-key-1234567890123
WHATSAPP_BRIDGE_TOKEN=
HEALTH_WHATSAPP_BRIDGE_URL=ws://whatsapp-bridge:3001

# Safe local defaults.
POSTGRES_PASSWORD=nanohealth
APP_RELEASE=local-dev
APP_DEPLOYED_AT=
NANOBOT_HEALTH_INSTANCE_IMAGE=healthclaw-local-orchestrator:latest
HEALTH_TELEGRAM_BOT_URL=
HEALTH_WHATSAPP_CHAT_URL=
NANOBOT_MULTI_TENANT=true
NANOBOT_SKIP_SETUP_PROVIDER=false
OPENWEARABLES_ENABLED=false
OPENWEARABLES_API_URL=
OPENWEARABLES_API_KEY=
OPENWEARABLES_TIMEOUT_SECONDS=20
OPENWEARABLES_SYNC_WINDOW_DAYS=3
OPENWEARABLES_STALE_AFTER_HOURS=36

# Family Setup (Local Ollama overrides)
NANOBOT_AGENTS__DEFAULTS__PROVIDER=ollama
NANOBOT_AGENTS__DEFAULTS__MODEL=gemma:7b
OLLAMA_API_BASE=http://host.docker.internal:11434
