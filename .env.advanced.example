# Advanced / power-user overrides for Healthclaw.
# None of this is required for a normal install — copy lines into your .env
# only if you know you need them.

# ─── Global provider fallback keys ────────────────────────────────────
# Per-user keys entered in web setup take precedence. These are only passed
# through to spawned coaches as a fallback when a user skips provider setup.
# MINIMAX_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=

# ─── Secrets (normally auto-generated by the bootstrap service) ────────
# Set these only if you must inject your own. If unset, Healthclaw generates
# and persists them on first run.
# HEALTH_VAULT_KEY=          # Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# POSTGRES_PASSWORD=

# ─── External connection overrides ────────────────────────────────────
# NANOBOT_HEALTH_REGISTRY_URL=postgresql://nanohealth:PASSWORD@postgres:5432/nanohealth
# NANOBOT_DATABASE_URL=postgresql://nanohealth:PASSWORD@postgres:5432/nanohealth
# ARQ_REDIS_URL=redis://redis:6379/0
# NANOBOT_STATE_DIR=nanobot_state   # host path or named volume for persistent state

# ─── Async spawn queue (uses the worker + redis) ──────────────────────
# NANOBOT_HEALTH_ASYNC_SPAWN=false

# ─── Deployment metadata (surfaced on /metrics) ───────────────────────
# APP_RELEASE=local
# APP_DEPLOYED_AT=

# ─── Channel deep links ───────────────────────────────────────────────
# HEALTH_TELEGRAM_BOT_URL=
# HEALTH_WHATSAPP_CHAT_URL=

# ─── WhatsApp bridge (requires an image built with NANOBOT_BUILD_BRIDGE=1) ──
# WHATSAPP_BRIDGE_TOKEN=
# HEALTH_WHATSAPP_BRIDGE_URL=ws://whatsapp-bridge:3001

# ─── Open Wearables (experimental) ────────────────────────────────────
# OPENWEARABLES_ENABLED=false
# OPENWEARABLES_API_URL=
# OPENWEARABLES_API_KEY=
# OPENWEARABLES_TIMEOUT_SECONDS=20
# OPENWEARABLES_SYNC_WINDOW_DAYS=3
# OPENWEARABLES_STALE_AFTER_HOURS=36
